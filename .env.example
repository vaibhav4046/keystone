# ==== KEYSTONE LLM KEYS (optional; app runs fully without any of these) ====
# Copy to .env and paste real keys. Never commit .env.
# PRIMARY  Cerebras   https://cloud.cerebras.ai
CEREBRAS_API_KEY=PASTE_YOUR_CEREBRAS_KEY_HERE
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=llama-3.3-70b
# FALLBACK 1  Groq     https://console.groq.com
GROQ_API_KEY=PASTE_YOUR_GROQ_KEY_HERE
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
# FALLBACK 2  Gemini   https://aistudio.google.com/apikey  (keep project FREE-ONLY)
GEMINI_API_KEY=PASTE_YOUR_GEMINI_KEY_HERE
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.5-flash-lite
# OPTIONAL  OpenRouter https://openrouter.ai
OPENROUTER_API_KEY=PASTE_YOUR_OPENROUTER_KEY_HERE
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# ==== end keys ====
